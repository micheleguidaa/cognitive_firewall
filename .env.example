# Copy to .env (git-ignored) and fill in. Leave CF_API_KEY empty to run fully
# offline on the heuristic backend. NEVER commit a real key.

# Backend: auto | local | openai | heuristic
CF_BACKEND=auto

# API key (read from the environment only; never written to any file by the app).
# Used for CF_BACKEND=openai, or by `auto` when no local vLLM endpoint is reachable.
CF_API_KEY=

# Local vLLM (OpenAI-compatible) endpoint for CF_BACKEND=local / auto.
CF_BASE_URL=http://localhost:8000/v1

# Gate-judge model. For OpenAI use e.g. gpt-4o-mini; for local vLLM the served name.
CF_MODEL=Qwen2.5-7B-Instruct

# Governed main LLM (defaults to CF_MODEL if unset).
CF_MAIN_MODEL=

# Fail policy when a gate errors: closed (->BLOCK) | flag (->FLAG, default) | open (->ALLOW)
CF_FAIL_MODE=flag

# Observe-only: compute decisions but never suppress output.
CF_DRY_RUN=false
